{
  "App": {
    "SelfUrl": "https://localhost:44353",
    "AngularUrl": "http://localhost:4200",
    "CorsOrigins": "https://*.CUInventory.com,http://localhost:4200,",
    "RedirectAllowedUrls": "http://localhost:4200,",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Server=(LocalDb)\\MSSQLLocalDB;Database=CUInventory;Trusted_Connection=True;TrustServerCertificate=true"
  },
  "AuthServer": {
    "Authority": "https://localhost:44353",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "CUInventory_Swagger",
    "CertificatePassPhrase": "2239ddbd-ef48-4c09-9ba1-d6e4c6151376"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "xWZHRsGpW68qI1ai"
  }}